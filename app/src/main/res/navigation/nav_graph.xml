<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/connection_status">

    <fragment
        android:id="@+id/connection_status"
        android:name="com.socks5.ui.connection.ConnectionStatusFragment"
        android:label="Connection"
        tools:layout="@layout/fragment_connection_status" />

    <fragment
        android:id="@+id/profile_list"
        android:name="com.socks5.ui.profiles.ProfileListFragment"
        android:label="Profiles"
        tools:layout="@layout/fragment_profile_list" />

    <fragment
        android:id="@+id/profile_detail"
        android:name="com.socks5.ui.profiles.ProfileDetailFragment"
        android:label="Edit Profile"
        tools:layout="@layout/fragment_profile_detail" />

    <fragment
        android:id="@+id/key_management"
        android:name="com.socks5.ui.keys.KeyManagementFragment"
        android:label="SSH Keys"
        tools:layout="@layout/fragment_key_management" />

    <fragment
        android:id="@+id/settings"
        android:name="com.socks5.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <action
        android:id="@+id/action_profiles_to_connection"
        app:destination="@id/connection_status" />

    <action
        android:id="@+id/action_profiles_to_detail"
        app:destination="@id/profile_detail" />

</navigation>
