<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/auto_connect_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setting_auto_connect" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/boot_start_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setting_boot_start" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/setting_dns_server">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dns_server_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:text="1.1.1.1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/setting_local_socks_port">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/socks_port_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="1080" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Battery Optimization -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:background="?android:attr/dividerVertical" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_battery_title"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/setting_battery_description"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/battery_settings_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:text="@string/setting_battery_action" />

        <!-- Custom Hosts -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:background="?android:attr/dividerVertical" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_custom_hosts_title"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/setting_custom_hosts_description"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary" />

        <TextView
            android:id="@+id/custom_hosts_empty_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/setting_custom_hosts_empty"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:gravity="center" />

        <LinearLayout
            android:id="@+id/custom_hosts_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/add_host_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:text="@string/setting_custom_hosts_add" />

        <!-- Donate -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:background="?android:attr/dividerVertical" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_donate_title"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/setting_donate_description"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/donate_address_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1BKDTNeDJJTqHGpDU3zRd3NaYKNwWt821F"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textIsSelectable="true"
                android:padding="8dp"
                android:background="?android:attr/selectableItemBackground" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/donate_copy_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                style="@style/Widget.Material3.Button.TextButton"
                android:text="@string/setting_donate_copy" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
